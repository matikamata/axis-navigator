      "level": "advanced",
      "sequence": [
        {
          "step": 1,
          "concept": "magga",
          "note": "The Noble Eightfold Path — the method"
        },
        {
          "step": 2,
          "concept": "phala",
          "note": "Fruition — the moment of attainment"
        },
        {
          "step": 3,
          "concept": "nibbana",
          "note": "Nibbāna — the unconditioned goal"
        }
      ]
    }
